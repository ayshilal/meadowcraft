{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "selfcaredb": "Host=<your-pg-host>.postgres.database.azure.com;Database=selfcaredb;Username=<username>;Password=<password>;SSL Mode=Require;Trust Server Certificate=true"
  },
  "AzureAdB2C": {
    "Authority": "https://{tenant}.b2clogin.com/{tenant}.onmicrosoft.com/B2C_1_signup_signin/v2.0",
    "ClientId": "{api-client-id}"
  },
  "AzureOpenAI": {
    "Endpoint": "https://<your-resource>.openai.azure.com",
    "DeploymentName": "gpt-4.1",
    "ApiKey": "<your-api-key>"
  },
  "AzureAISearch": {
    "IndexName": "skincare-knowledge",
    "ApiKey": "<your-search-api-key>"
  },
  "OpenBeautyFacts": {
    "BaseUrl": "https://world.openbeautyfacts.org/api/v2"
  }
}
